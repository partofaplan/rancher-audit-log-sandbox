# More info: https://docs.docker.com/engine/reference/builder/#dockerignore-file
# Ignore build and test binaries, except the cross-compiled manager binaries that the
# Dockerfile copies in (produced by ./build-image.sh).
bin/*
!bin/manager-linux-*
# vendor/ is for offline `go build`; the Dockerfile only copies the prebuilt binary, so it
# isn't needed in the build context.
vendor/
