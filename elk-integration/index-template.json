{
  "index_patterns": ["rancher-audit*"],
  "priority": 200,
  "_meta": {
    "description": "Rancher UI audit logs shipped by the rancher-audit-log-operator (Filebeat).",
    "managed_by": "rancher-audit-log-operator"
  },
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 1,
      "mapping.total_fields.limit": 2000
    },
    "mappings": {
      "dynamic": true,
      "properties": {
        "@timestamp": { "type": "date" },
        "audit": {
          "properties": {
            "actor":        { "type": "keyword" },
            "verb":         { "type": "keyword" },
            "resource":     { "type": "keyword" },
            "target":       { "type": "keyword" },
            "category":     { "type": "keyword" },
            "event":        { "type": "keyword" },
            "responseCode": { "type": "integer" },
            "summary":      { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 2048 } } }
          }
        },
        "rancher": {
          "properties": {
            "auditID":      { "type": "keyword" },
            "method":       { "type": "keyword" },
            "requestURI":   { "type": "keyword", "ignore_above": 4096, "fields": { "text": { "type": "text" } } },
            "responseCode": { "type": "integer" },
            "user":         { "properties": { "name": { "type": "keyword" } } }
          }
        },
        "message": { "type": "text" }
      }
    }
  }
}
